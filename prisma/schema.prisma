generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  SELLER
  USER
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  BLACKLISTED
}

enum UserStatus {
  ACTIVE
  BLACKLISTED
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAYMENT_FAILED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  ORDER
  SELLER_SUBSCRIPTION
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AddressType {
  HOME
  OFFICE
  OTHERS
}

enum PrescriptionStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Super Admin ─────────────────────────────────────────────────────────────

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("Super Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}

// ─── Users (Buyers) ──────────────────────────────────────────────────────────

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  phone       String     @unique
  password    String
  name        String
  isVerified  Boolean    @default(false)
  status      UserStatus @default(ACTIVE)
  otpCode     String?
  otpExpiry   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  addresses     Address[]
  orders        Order[]
  ratings       Rating[]
  prescriptions Prescription[]

  @@map("users")
}

// ─── Sellers ─────────────────────────────────────────────────────────────────

model Seller {
  id               String       @id @default(cuid())
  email            String       @unique
  phone            String       @unique
  password         String?
  businessName     String
  ownerName        String
  panCardNumber    String       @unique
  panCardImageUrl  String
  gstNumber        String?
  addressLine      String
  city             String
  state            String
  pincode          String
  bankAccountName  String
  bankAccountNumber String
  bankIfscCode     String
  isVerified       Boolean      @default(false) // email verified
  status           SellerStatus @default(PENDING)
  otpCode          String?
  otpExpiry        DateTime?
  expectedDeliveryDays Int      @default(3)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  products          Product[]
  orderItems        OrderItem[]
  subscription      SellerSubscription?
  wallet            SellerWallet?
  withdrawRequests  WithdrawRequest[]
  ratings           Rating[]

  @@map("sellers")
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@map("categories")
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id                String   @id @default(cuid())
  sellerId          String
  categoryId        String
  name              String
  slug              String   @unique
  description       String
  price             Float
  discountedPrice   Float?
  quantity          Int      @default(0)
  images            String[] // URLs from uploadthing
  uses              String[]
  contraindications String[]
  sideEffects       String[]
  precautions       String[]
  warnings          String[]
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seller     Seller     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id])
  faqs       ProductFaq[]
  orderItems OrderItem[]

  @@map("products")
}

model ProductFaq {
  id        String   @id @default(cuid())
  productId String
  question  String
  answer    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_faqs")
}

// ─── Addresses ────────────────────────────────────────────────────────────────

model Address {
  id          String      @id @default(cuid())
  userId      String
  type        AddressType @default(HOME)
  fullName    String
  phone       String
  addressLine String
  city        String
  state       String
  pincode     String
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  userId          String
  addressId       String
  status          OrderStatus @default(PENDING)
  subtotal        Float       // sum of all products
  deliveryCharge  Float       @default(0)
  gstAmount       Float       @default(0)
  totalAmount     Float       // subtotal + delivery + gst
  prescriptionId  String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  address      Address       @relation(fields: [addressId], references: [id])
  orderItems   OrderItem[]
  payment      Payment?
  prescription Prescription? @relation(fields: [prescriptionId], references: [id])
  ratings      Rating[]

  @@map("orders")
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  productId        String
  sellerId         String
  quantity         Int
  price            Float           // price at time of order
  discountedPrice  Float?
  totalPrice       Float           // quantity * effective price
  status           OrderItemStatus @default(PENDING)
  expectedDelivery DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  seller  Seller  @relation(fields: [sellerId], references: [id])

  @@map("order_items")
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                String        @id @default(cuid())
  orderId           String?       @unique
  sellerId          String?       // for subscription payments
  type              PaymentType
  amount            Float
  status            PaymentStatus @default(PENDING)
  transactionId     String?       @unique // from payment gateway
  gatewayResponse   Json?         // raw gateway response
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order? @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─── Seller Subscription ─────────────────────────────────────────────────────

model SellerSubscription {
  id            String             @id @default(cuid())
  sellerId      String             @unique
  status        SubscriptionStatus @default(INACTIVE)
  amount        Float
  startDate     DateTime?
  endDate       DateTime?
  transactionId String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("seller_subscriptions")
}

// ─── Seller Wallet ────────────────────────────────────────────────────────────

model SellerWallet {
  id           String   @id @default(cuid())
  sellerId     String   @unique
  balance      Float    @default(0)
  totalEarned  Float    @default(0)
  totalWithdrawn Float  @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seller       Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("seller_wallets")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  walletId    String
  amount      Float
  type        String   // CREDIT | DEBIT
  description String
  orderId     String?
  createdAt   DateTime @default(now())

  wallet SellerWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
}

// ─── Withdraw Requests ────────────────────────────────────────────────────────

model WithdrawRequest {
  id            String         @id @default(cuid())
  sellerId      String
  amount        Float
  status        WithdrawStatus @default(PENDING)
  adminNote     String?
  processedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("withdraw_requests")
}

// ─── Prescriptions ────────────────────────────────────────────────────────────

model Prescription {
  id           String             @id @default(cuid())
  userId       String
  imageUrl     String
  status       PrescriptionStatus @default(PENDING)
  aiResult     Json?              // Gemini AI analysis result
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("prescriptions")
}

// ─── Ratings ─────────────────────────────────────────────────────────────────

model Rating {
  id        String   @id @default(cuid())
  userId    String
  sellerId  String
  orderId   String
  rating    Int      // 1-5
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id])

  @@unique([userId, sellerId, orderId])
  @@map("ratings")
}

// ─── App Settings (managed by super admin) ───────────────────────────────────

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
