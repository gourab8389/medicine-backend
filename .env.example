# Copy to .env and fill values. Do NOT commit secrets.
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT secrets (min 32 chars)
JWT_ACCESS_SECRET=replace_with_32_char_secret
JWT_REFRESH_SECRET=replace_with_32_char_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM="Medicine Store <noreply@medicinestore.com>"

GEMINI_API_KEY=your_gemini_api_key
FRONTEND_URL=http://localhost:3000
OTP_EXPIRY_MINUTES=10

# Super admin (example)
SUPER_ADMIN_EMAIL=admin@medicinestore.com
SUPER_ADMIN_PASSWORD=Admin@123456
